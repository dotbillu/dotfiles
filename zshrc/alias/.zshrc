alias localapp="nvim ~/.local/share/applications/"
alias uconf="~/scripts/uconf.sh"

alias yay=paru
#Configs
alias vapp="nvim /home/abhay/.local/share/applications"
alias sddmgreet="sddm-greeter --test-mode --theme /usr/share/sddm/themes/aerial-sddm-theme"
#daily use 
alias ping=gping
alias cpwd="pwd | wl-copy"
alias nano=nvim
alias kro=kiro-cli
alias kiro="kiro --disable-gpu ."
alias kirop="HOME=$HOME/.kiro-personal-home kiro --new-window"
alias chrome="prime-run google-chrome-stable --ozone-platform=x11"
alias snapshot="sudo snapper -c root create --description "$(date +'%Y-%m-%d')""
alias vi=nvim

alias vdt=open_dotfiles_of
alias cdt=go_to_dotfiles_of



alias zreload="rm -f ~/*.zwc ~/.config/zshrc/**/*.zwc ~/.zcompdump*.zwc && zcompile ~/.zshrc ~/.config/zshrc/.zshrc.main ~/.config/zshrc/theme/.zshrc ~/.config/zshrc/alias/.zshrc ~/.config/zshrc/alias/.zshrc.common ~/.config/zshrc/alias/services/.zshrc.cloudfare ~/.config/zshrc/alias/services/.zshrc.configs ~/.config/zshrc/lazy/.zshrc && exec zsh"
