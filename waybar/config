[
  {
    "layer": "top",
    "position": "top",
    "height": 24,
    "spacing": 5,
    "modules-left": [
      "clock"
    ],
    "modules-center": [
      "hyprland/window"
    ],
    "modules-right": [
      "mpd",
      "idle_inhibitor",
      "temperature",
      "network",
      "pulseaudio",
      "battery"
    ],
    "hyprland/window": {
      "format": "{class}",
      "max-length": 20,
      "rewrite": {
        "^(?!.*\\S).*": "Finder"
      }
    },



    "sway/mode": {
      "format": "<span style=\"italic\">{}</span>"
    },
    "sway/scratchpad": {
      "format": "{icon} {count}",
      "show-empty": false,
      "format-icons": [
        "",
        "пЛТ"
      ],
      "tooltip": true,
      "tooltip-format": "{app}: {title}"
    },
    "mpd": {
      "format": "пАБ  {title} - {artist} {stateIcon} [{elapsedTime:%M:%S}/{totalTime:%M:%S}] {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}[{songPosition}/{queueLength}] [{volume}%]",
      "format-disconnected": "пАБ Disconnected",
      "format-stopped": "пАБ {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped",
      "unknown-tag": "N/A",
      "interval": 2,
      "consume-icons": {
        "on": "пГД "
      },
      "random-icons": {
        "on": "пБі "
      },
      "repeat-icons": {
        "on": "пАЮ "
      },
      "single-icons": {
        "on": "пАЮ1 "
      },
      "state-icons": {
        "paused": "пБМ",
        "playing": "пБЛ"
      },
      "tooltip-format": "MPD (connected)",
      "tooltip-format-disconnected": "MPD (disconnected)",
      "on-click": "mpc toggle",
      "on-click-right": "foot -a ncmpcpp ncmpcpp",
      "on-scroll-up": "mpc volume +2",
      "on-scroll-down": "mpc volume -2"
    },
    "idle_inhibitor": {
      "format": "{icon}",
      "format-icons": {
        "activated": "пБЃ",
        "deactivated": "пБ∞"
      }
    },
    "tray": {
      "spacing": 10
    },
    "clock": {
      "format": "{:%Y-%m-%d %H:%M}",
      "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "cpu": {
      "format": "пЛЫ  {usage}%"
    },
    "memory": {
      "format": "пГЙ {}%"
    },
    "temperature": {
      "thermal-zone": 2,
      "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
      "critical-threshold": 80,
      "format-critical": "{icon} {temperatureC}¬∞C",
      "format": "{icon} {temperatureC}¬∞C",
      "format-icons": [
        "пЭЂ",
        "пЛЙ",
        "пЭ©"
      ]
    },
    "backlight": {
      "format": "{icon} {percent}%",
      "format-icons": [
        "оОН",
        "оПУ",
        "оПС",
        "оПП",
        "оПО",
        "оПН",
        "оПК",
        "оПИ",
        "оОЫ"
      ]
    },
    "battery": {
      "states": {
        "warning": 30,
        "critical": 15
      },
      "format": "{icon} {capacity}%",
      "format-charging": "пЧІ {capacity}%",
      "format-plugged": "пЗ¶ {capacity}%",
      "format-alt": "{icon} {time}",
      "format-icons": [
        "пЙД",
        "пЙГ",
        "пЙВ",
        "пЙБ",
        "пЙА"
      ]
    },

    "network": {
      "format-wifi": "{essid} ({signalStrength}%) пЗЂ",
      "format-ethernet": "пЮЦ {ifname}",
      "tooltip-format": "пЮЦ {ifname} via {gwaddr}",
      "format-linked": "пЮЦ {ifname} (No IP)",
      "format-disconnected": "Disconnected вЪ† {ifname}",
      "format-alt": "пЮЦ {ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
      "scroll-step": 5,
      "format": "{icon}  {volume}%",
      "format-bluetooth": " {icon} {volume}%",
      "format-bluetooth-muted": " ",
      "format-muted": " ",
      "format-icons": {
        "default": [
          "пА¶",
          "пАІ",
          "пА®"
        ]
      },
      "on-click": "pavucontrol",
      "on-click-right": "foot -a pw-top pw-top"
    }
  }
]
